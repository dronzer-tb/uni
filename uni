# ── UPDATE ───────────────────────────────────────────────────
cmd_update() {
    init_registry
    header "Updating all backends"

    if has_apt; then
        info "$(apt_cmd)..."
        sudo "$(apt_cmd)" update && sudo "$(apt_cmd)" upgrade -y
        echo ""
    fi

    local fp_pid="" snap_pid=""

    if has_flatpak; then
        info "Flatpak... ${DIM}(background)${RESET}"
        flatpak update --noninteractive -y &
        fp_pid=$!
    fi

    if has_snap; then
        info "Snap... ${DIM}(background)${RESET}"
        sudo snap refresh &
        snap_pid=$!
    fi

    if [[ -n "$fp_pid" ]]; then
        wait "$fp_pid" && success "Flatpak updated." || warn "Flatpak update encountered errors."
    fi
    if [[ -n "$snap_pid" ]]; then
        wait "$snap_pid" && success "Snap updated." || warn "Snap update encountered errors."
    fi

    success "All backends updated."
}

# ── UNINSTALL ────────────────────────────────────────────────
cmd_uninstall() {
    header "uni uninstall"
    
    warn "This will completely remove uni and its data."
    echo ""
    echo -e "  ${DIM}Directories that will be removed:${RESET}"
    echo -e "  ${DIM}• uni binary${RESET}"
    echo -e "  ${DIM}• $HOME/.local/share/uni/  (registry, appimages, icons)${RESET}"
    echo -e "  ${DIM}• $HOME/.cache/uni/  (cache)${RESET}"
    echo -e "  ${DIM}• PATH entries in shell configs${RESET}"
    echo ""
    echo -e "  ${BOLD}Packages installed via uni will ${CYAN}NOT${RESET}${BOLD} be removed.${RESET}"
    echo ""
    
    read -p "$(echo -e "${RED}${BOLD}Uninstall uni? Type 'yes' to confirm:${RESET} ")" -r confirm
    if [[ "$confirm" != "yes" ]]; then
        warn "Uninstall cancelled."
        return 1
    fi
    
    echo ""
    info "Removing uni..."
    
    local uni_path
    uni_path=$(command -v uni 2>/dev/null || echo "$REAL_HOME/.local/bin/uni")
    
    # Remove binary
    if [[ -f "$uni_path" ]]; then
        rm -f "$uni_path" && success "Removed: $uni_path" || warn "Could not remove $uni_path"
    fi
    
    # Remove uni directories
    if [[ -d "$REAL_HOME/.local/share/uni" ]]; then
        rm -rf "$REAL_HOME/.local/share/uni" && success "Removed: $REAL_HOME/.local/share/uni/" || warn "Could not remove uni data"
    fi
    
    if [[ -d "$REAL_HOME/.cache/uni" ]]; then
        rm -rf "$REAL_HOME/.cache/uni" && success "Removed: $REAL_HOME/.cache/uni/" || warn "Could not remove cache"
    fi
    
    # Remove PATH entries from shell configs
    for rc_file in ~/.bashrc ~/.zshrc ~/.bash_profile ~/.zprofile; do
        if [[ -f "$rc_file" ]]; then
            if grep -q "\.local/bin.*# uni" "$rc_file"; then
                sed -i '/\.local\/bin.*# uni/d' "$rc_file"
                success "Updated: $rc_file"
            fi
        fi
    done
    
    echo ""
    success "uni has been completely removed."
    echo -e "  ${DIM}Run: ${CYAN}source ~/.bashrc${RESET}${DIM} to update your shell${RESET}"
    echo ""
}

# ── SELF-UPDATE ──────────────────────────────────────────────
cmd_self_update() {
    header "uni self-update"

    local force=0
    for arg in "$@"; do
        case "$arg" in
            -f|--force) force=1 ;;
        esac
    done

    local self_path
    self_path=$(command -v uni 2>/dev/null || echo "$REAL_HOME/.local/bin/uni")

    info "Checking latest version..."
    local latest_ver fetch_status
    latest_ver=$(fetch_uni_latest_version 10); fetch_status=$?
    case "$fetch_status" in
        0) ;;
        1) die "Could not reach GitHub. Check your connection." ;;
        *) die "Could not determine latest version from GitHub." ;;
    esac

    local tmp
    tmp=$(mktemp)
    curl -fsSL "$UNI_RAW_URL" -o "$tmp" \
        || { rm -f "$tmp"; die "Download failed."; }

    # Sanity check
    if ! head -1 "$tmp" | grep -q "bash"; then
        rm -f "$tmp"
        die "Downloaded file doesn't look right. Aborting."
    fi

    if cmp -s "$tmp" "$self_path"; then
        rm -f "$tmp"
        success "Already up to date (v${UNI_VERSION})."
        return 0
    fi

    if version_gt "$UNI_VERSION" "$latest_ver"; then
        if (( force )); then
            warn "Remote version (v${latest_ver}) is older than installed (v${UNI_VERSION}). Forcing as requested."
        else
            rm -f "$tmp"
            die "Remote version (v${latest_ver}) is older than installed (v${UNI_VERSION}). Aborting. (Use 'uni self-update --force' to override.)"
        fi
    fi

    if version_gt "$latest_ver" "$UNI_VERSION"; then
        info "Updating ${BOLD}v${UNI_VERSION}${RESET} → ${BOLD}v${latest_ver}${RESET}..."
    else
        info "Updating to latest commit on ${BOLD}master${RESET} (version unchanged: v${UNI_VERSION})..."
    fi

    chmod +x "$tmp"
    
    # Try to write directly, if that fails (permissions), try with sudo
    if ! mv "$tmp" "$self_path" 2>/dev/null; then
        if sudo -n true 2>/dev/null; then
            sudo mv "$tmp" "$self_path" || { rm -f "$tmp"; die "Could not write to ${self_path}. Try: sudo uni self-update"; }
        else
            rm -f "$tmp"
            die "Permission denied: ${self_path}. Try: sudo uni self-update"
        fi
    fi

    # Bust the update-check cache so the banner doesn't linger
    rm -f "$UNI_CACHE_DIR/latest_version.txt"

    success "uni updated to v${latest_ver}"
}


# ── INDEX / SEARCH / SOURCES / INFO (0.6.0) ──────────────────
# Local SQLite (FTS5) package index that powers the Qt UI's fast search.
# The CLI uses this index opportunistically; the existing live `parallel_search`
# path remains the default for `uni install` and is the fallback when no index exists.

_ensure_index_schema() {
    local db="$1"
    command -v sqlite3 >/dev/null 2>&1 || die "sqlite3 is required for indexing. Install: uni install sqlite3 --source apt"
    mkdir -p "$(dirname "$db")"
    sqlite3 "$db" <<'SQL'
PRAGMA journal_mode=WAL;
CREATE VIRTUAL TABLE IF NOT EXISTS pkgs USING fts5(
    name,
    description,
    version UNINDEXED,
    backend UNINDEXED,
    source_url UNINDEXED,
    size_bytes UNINDEXED,
    last_seen UNINDEXED,
    tokenize='porter unicode61'
);
SQL
}

_index_apt() {
    local db="$1" now="$2"
    has_apt || return 0
    info "Indexing apt..."
    apt-cache dumpavail 2>/dev/null | python3 - "$db" "$now" <<'PY'
import sys, sqlite3, re
db_path, now = sys.argv[1], int(sys.argv[2])
conn = sqlite3.connect(db_path); cur = conn.cursor()
rows, pkg = [], {}
def flush():
    if pkg.get('name'):
        rows.append((
            pkg['name'],
            pkg.get('description', '')[:500],
            pkg.get('version', ''),
            'apt', '',
            int(pkg.get('size', '0') or 0),
            now,
        ))
for line in sys.stdin:
    if line.strip() == '':
        flush(); pkg = {}; continue
    if line.startswith(' '): continue
    m = re.match(r'^([A-Za-z-]+):\s*(.*)', line)
    if not m: continue
    k, v = m.group(1).lower(), m.group(2).strip()
    if   k == 'package':     pkg['name'] = v
    elif k == 'description' and 'description' not in pkg: pkg['description'] = v
    elif k == 'version' and 'version' not in pkg: pkg['version'] = v
    elif k == 'installed-size': pkg['size'] = v
flush()
cur.executemany(
    'INSERT INTO pkgs (name, description, version, backend, source_url, size_bytes, last_seen) VALUES (?, ?, ?, ?, ?, ?, ?)',
    rows,
)
conn.commit(); conn.close()
print(f'  → {len(rows)} apt packages', file=sys.stderr)
PY
}

_index_flatpak() {
    local db="$1" now="$2"
    has_flatpak || return 0
    info "Indexing flatpak..."
    flatpak remote-ls --app --columns=application,name,version,description,size 2>/dev/null \
        | python3 - "$db" "$now" <<'PY'
import sys, sqlite3
db_path, now = sys.argv[1], int(sys.argv[2])
conn = sqlite3.connect(db_path); cur = conn.cursor()
rows = []
for line in sys.stdin:
    parts = line.rstrip('\n').split('\t')
    if len(parts) < 2: continue
    app_id = parts[0].strip()
    name   = parts[1].strip() if len(parts) > 1 else app_id
    ver    = parts[2].strip() if len(parts) > 2 else ''
    desc   = parts[3].strip() if len(parts) > 3 else ''
    raw_sz = parts[4].strip() if len(parts) > 4 else ''
    # raw_sz can be "12.3 MB" — best effort parse to bytes
    size = 0
    try:
        num, unit = raw_sz.split()[0], (raw_sz.split()[1] if len(raw_sz.split()) > 1 else 'B').upper()
        mult = {'B':1,'KB':1024,'MB':1024**2,'GB':1024**3}.get(unit, 1)
        size = int(float(num) * mult)
    except Exception:
        size = 0
    rows.append((name or app_id, desc, ver, 'flatpak', app_id, size, now))
cur.executemany(
    'INSERT INTO pkgs (name, description, version, backend, source_url, size_bytes, last_seen) VALUES (?, ?, ?, ?, ?, ?, ?)',
    rows,
)
conn.commit(); conn.close()
print(f'  → {len(rows)} flatpak packages', file=sys.stderr)
PY
}

cmd_index() {
    local refresh=0
    for arg in "$@"; do
        case "$arg" in
            --refresh) refresh=1 ;;
        esac
    done

    _ensure_index_schema "$UNI_INDEX_DB"

    if (( ! refresh )); then
        header "uni index"
        local count
        count=$(sqlite3 "$UNI_INDEX_DB" "SELECT COUNT(*) FROM pkgs;" 2>/dev/null || echo 0)
        info "Index: ${BOLD}${count}${RESET} packages at ${DIM}${UNI_INDEX_DB}${RESET}"
        info "Refresh with: ${BOLD}uni index --refresh${RESET}"
        return 0
    fi

    header "uni index --refresh"
    local now
    now=$(date +%s)

    # Clear and rebuild. WAL readers continue to see the previous snapshot
    # until each backend's INSERT transaction commits.
    sqlite3 "$UNI_INDEX_DB" "DELETE FROM pkgs;"
    _index_apt     "$UNI_INDEX_DB" "$now"
    _index_flatpak "$UNI_INDEX_DB" "$now"
    # snap and github are intentionally not enumerable — searched live only.

    local count
    count=$(sqlite3 "$UNI_INDEX_DB" "SELECT COUNT(*) FROM pkgs;")
    success "Indexed ${BOLD}${count}${RESET} packages."
}

_search_cached() {
    local query="$1"
    [[ -f "$UNI_INDEX_DB" ]] || die "Index not built. Run: uni index --refresh"
    python3 - "$UNI_INDEX_DB" "$UNI_SOURCES_JSON" "$query" <<'PY'
import sys, sqlite3, json, os
db, sources_path, q = sys.argv[1], sys.argv[2], sys.argv[3]
sources = {}
if os.path.exists(sources_path):
    try:
        with open(sources_path) as f: sources = json.load(f)
    except Exception: sources = {}
conn = sqlite3.connect(db); cur = conn.cursor()
# Escape FTS5 special chars, then prefix-match each token.
safe = ''.join(c for c in q if c.isalnum() or c in ' -_.+')
tokens = [t for t in safe.split() if t]
if not tokens:
    print('[]'); sys.exit(0)
fts_q = ' '.join(t + '*' for t in tokens)
try:
    cur.execute(
        'SELECT name, description, version, backend, source_url, size_bytes '
        'FROM pkgs WHERE pkgs MATCH ? ORDER BY rank LIMIT 200',
        (fts_q,),
    )
    rows = cur.fetchall()
except sqlite3.OperationalError:
    rows = []
ql = q.lower()
out = []
for name, desc, ver, backend, url, size in rows:
    rank = sources.get(backend, {}).get('rank', 99)
    out.append({
        'name': name,
        'description': desc,
        'version': ver,
        'backend': backend,
        'source_url': url,
        'size_bytes': int(size) if str(size).isdigit() else 0,
        'source_speed_rank': rank,
    })
out.sort(key=lambda r: (0 if r['name'].lower() == ql else 1, r['source_speed_rank']))
print(json.dumps(out))
PY
}

cmd_search() {
    local cached=0 query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cached)  cached=1; shift ;;
            --json)    UNI_JSON=1; cached=1; shift ;;
            --) shift; break ;;
            -*) shift ;;
            *)  query="$1"; shift ;;
        esac
    done
    [[ -z "$query" ]] && die "Usage: uni search [--cached] <query>"

    if (( cached )); then
        _search_cached "$query"
        return $?
    fi

    header "uni search ${query}"
    info "Live search (use ${BOLD}--cached${RESET} for the local index)..."
    parallel_search "$query"
}

cmd_sources() {
    local do_bench=0 force=0
    for arg in "$@"; do
        case "$arg" in
            --benchmark) do_bench=1 ;;
            --force)     force=1 ;;
        esac
    done

    mkdir -p "$UNI_DATA_DIR"

    # Serve cached if fresh and benchmark not forced.
    if (( do_bench )) && [[ -f "$UNI_SOURCES_JSON" ]] && (( ! force )); then
        local age now mtime
        now=$(date +%s)
        mtime=$(stat -c %Y "$UNI_SOURCES_JSON" 2>/dev/null || echo 0)
        age=$(( now - mtime ))
        if (( age < UNI_SOURCES_TTL )); then
            cat "$UNI_SOURCES_JSON"
            return 0
        fi
    fi

    if (( ! do_bench )); then
        [[ -f "$UNI_SOURCES_JSON" ]] && cat "$UNI_SOURCES_JSON" || echo '{}'
        return 0
    fi

    # One canonical small probe URL per backend.
    local apt_probe="http://archive.ubuntu.com/ubuntu/dists/jammy/InRelease"
    local fp_probe="https://dl.flathub.org/repo/summary"
    local sn_probe="https://api.snapcraft.io/v2/snaps/info/hello?architecture=amd64&fields=name"
    local gh_probe="https://raw.githubusercontent.com/torvalds/linux/master/README"

    _probe() {
        curl -sS --max-time 8 -o /dev/null \
            -w '%{speed_download} %{time_total}' "$1" 2>/dev/null || echo "0 0"
    }

    local apt_r fp_r sn_r gh_r
    apt_r=$(_probe "$apt_probe")
    fp_r=$( _probe "$fp_probe")
    sn_r=$( _probe "$sn_probe")
    gh_r=$( _probe "$gh_probe")

    python3 - "$UNI_SOURCES_JSON" "$apt_r" "$fp_r" "$sn_r" "$gh_r" <<'PY'
import sys, json
out_path = sys.argv[1]
def parse(s):
    p = s.split()
    if len(p) < 2: return (0.0, 0)
    try:
        bps = float(p[0]); t = float(p[1])
    except ValueError: return (0.0, 0)
    return (round(bps * 8 / 1_000_000, 1), int(t * 1000))

names = ('apt', 'flatpak', 'snap', 'github')
data = {}
for name, raw in zip(names, sys.argv[2:]):
    mbps, lat = parse(raw)
    data[name] = {'speed_mbps': mbps, 'latency_ms': lat}
order = sorted(names, key=lambda k: -data[k]['speed_mbps'])
for i, b in enumerate(order, 1):
    data[b]['rank'] = i
with open(out_path, 'w') as f:
    json.dump(data, f, indent=2)
print(json.dumps(data))
PY
}

cmd_info() {
    local pkg="" json_mode=0
    for arg in "$@"; do
        case "$arg" in
            --json) json_mode=1 ;;
            -*) ;;
            *) [[ -z "$pkg" ]] && pkg="$arg" ;;
        esac
    done
    [[ -z "$pkg" ]] && die "Usage: uni info <package> [--json]"

    if has_apt && apt-cache show "$pkg" 2>/dev/null | head -1 | grep -q '^Package:'; then
        if (( json_mode )); then
            apt-cache show "$pkg" 2>/dev/null | python3 - "$pkg" <<'PY'
import sys, json, re
target = sys.argv[1]
out = {'backend': 'apt', 'name': target, 'depends': []}
for line in sys.stdin:
    if line.strip() == '' and 'name' in out: break
    if line.startswith(' '): continue
    m = re.match(r'^([A-Za-z-]+):\s*(.*)', line)
    if not m: continue
    k, v = m.group(1).lower(), m.group(2).strip()
    if   k == 'package':     out['name'] = v
    elif k == 'version' and 'version' not in out: out['version'] = v
    elif k == 'description' and 'description' not in out: out['description'] = v
    elif k == 'homepage':    out['homepage'] = v
    elif k == 'depends':
        out['depends'] = [d.split()[0].strip() for d in v.split(',') if d.strip()]
    elif k == 'installed-size' and v.isdigit():
        out['size_kb'] = int(v)
print(json.dumps(out))
PY
        else
            apt-cache show "$pkg" 2>/dev/null | sed -n '1,/^$/p'
        fi
        return 0
    fi

    if has_flatpak && flatpak info "$pkg" >/dev/null 2>&1; then
        if (( json_mode )); then
            python3 - "$pkg" <<PY
import json
print(json.dumps({'backend': 'flatpak', 'name': '$pkg', 'depends': []}))
PY
        else
            flatpak info "$pkg"
        fi
        return 0
    fi

    die "Package not found: $pkg"
}


# ── INTERCEPT ────────────────────────────────────────────────
# Writes shell functions to the user's rc file that wrap apt/nala/snap/flatpak
# so they all route through uni. `uni intercept off` removes them.

_UNI_INTERCEPT_BLOCK_START="# >>> uni intercept begin <<<"
_UNI_INTERCEPT_BLOCK_END="# >>> uni intercept end <<<"

_intercept_shell_functions() {
    cat << 'SHELLEOF'
# Intercept apt / nala / snap / flatpak → uni
apt()     { command uni install "$@" 2>/dev/null || command apt "$@"; }
nala()    { command uni install "$@" 2>/dev/null || command nala "$@"; }
snap()    {
    case "${1:-}" in
        install) shift; command uni install --source snap "$@" ;;
        remove)  shift; command uni remove "$@" ;;
        *)       command snap "$@" ;;
    esac
}
flatpak() {
    case "${1:-}" in
        install) shift; command uni install --source flatpak "$@" ;;
        uninstall|remove) shift; command uni remove "$@" ;;
        *)       command flatpak "$@" ;;
    esac
}
SHELLEOF
}

_detect_rc_file() {
    case "${SHELL:-}" in
        */zsh)  echo "$REAL_HOME/.zshrc" ;;
        */fish) echo "$REAL_HOME/.config/fish/config.fish" ;;
        *)      echo "$REAL_HOME/.bashrc" ;;
    esac
}

cmd_intercept() {
    local action="${1:-status}"
    local rc_file
    rc_file=$(_detect_rc_file)

    case "$action" in
        on)
            if grep -q "$_UNI_INTERCEPT_BLOCK_START" "$rc_file" 2>/dev/null; then
                warn "Intercept already enabled in ${rc_file}"
                return 0
            fi

            {
                echo ""
                echo "$_UNI_INTERCEPT_BLOCK_START"
                _intercept_shell_functions
                echo "$_UNI_INTERCEPT_BLOCK_END"
            } >> "$rc_file"

            success "Intercept enabled in ${BOLD}${rc_file}${RESET}"
            warn "Reload your shell: ${BOLD}source ${rc_file}${RESET}"
            echo ""
            echo -e "  ${DIM}apt install htop  →  uni install htop --source apt${RESET}"
            echo -e "  ${DIM}flatpak install X →  uni install X --source flatpak${RESET}"
            echo -e "  ${DIM}snap install X    →  uni install X --source snap${RESET}"
            ;;

        off)
            if ! grep -q "$_UNI_INTERCEPT_BLOCK_START" "$rc_file" 2>/dev/null; then
                warn "Intercept is not currently enabled in ${rc_file}"
                return 0
            fi

            # Remove the block between the markers (inclusive)
            local tmp
            tmp=$(mktemp)
            python3 - "$rc_file" "$_UNI_INTERCEPT_BLOCK_START" "$_UNI_INTERCEPT_BLOCK_END" "$tmp" << 'PYEOF'
import sys
src, start_marker, end_marker, dst = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
with open(src) as f:
    lines = f.readlines()
out, skip = [], False
for line in lines:
    if start_marker in line:
        skip = True
    if not skip:
        out.append(line)
    if end_marker in line:
        skip = False
# Strip trailing blank lines left by the removed block
while out and out[-1].strip() == '':
    out.pop()
out.append('\n')
with open(dst, 'w') as f:
    f.writelines(out)
PYEOF
            mv "$tmp" "$rc_file"
            success "Intercept removed from ${BOLD}${rc_file}${RESET}"
            warn "Reload your shell: ${BOLD}source ${rc_file}${RESET}"
            ;;

        status)
            if grep -q "$_UNI_INTERCEPT_BLOCK_START" "$rc_file" 2>/dev/null; then
                success "Intercept is ${BOLD}ON${RESET} ${DIM}(${rc_file})${RESET}"
            else
                info "Intercept is ${BOLD}OFF${RESET}"
            fi
            ;;

        *)
            die "Usage: uni intercept [on|off|status]"
            ;;
    esac
}


