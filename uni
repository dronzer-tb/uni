}

# ── Backend detection ────────────────────────────────────────
has_nala()    { command -v nala    &>/dev/null; }
has_apt()     { command -v apt     &>/dev/null; }
has_flatpak() { command -v flatpak &>/dev/null; }
has_snap()    { command -v snap    &>/dev/null; }
has_dpkg()    { command -v dpkg    &>/dev/null; }

apt_cmd() { has_nala && echo "nala" || echo "apt"; }

# ── System arch ──────────────────────────────────────────────
sys_arch() {
    case "$(uname -m)" in
        x86_64)  echo "amd64" ;;
        aarch64) echo "arm64" ;;
        armv7l)  echo "armhf" ;;
        *)       uname -m ;;
    esac
}

arch_patterns() {
    case "$(uname -m)" in
        x86_64)  echo "x86_64 amd64 x64" ;;
        aarch64) echo "aarch64 arm64" ;;
        armv7l)  echo "armv7l armhf arm" ;;
        *)       uname -m ;;
    esac
}

# ── Version comparison ───────────────────────────────────────
# Returns 0 if $1 > $2 (semver)
version_gt() {
    python3 -c "
import sys
a = tuple(int(x) for x in sys.argv[1].lstrip('v').split('.'))
b = tuple(int(x) for x in sys.argv[2].lstrip('v').split('.'))
sys.exit(0 if a > b else 1)
" "$1" "$2" 2>/dev/null
}

fetch_uni_latest_version() {
    local timeout="${1:-10}"
    local release_json latest_ver raw_script

    release_json=$(curl -sS --max-time "$timeout" \
        -H "Accept: application/vnd.github+json" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        "https://api.github.com/repos/${UNI_REPO}/releases/latest" 2>/dev/null || true)

    latest_ver=$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); tag=d.get('tag_name',''); print(tag.lstrip('v') if tag else '')" \
        "$release_json" 2>/dev/null || echo "")
    if [[ -n "$latest_ver" ]]; then
        echo "$latest_ver"
        return 0
    fi

    raw_script=$(curl -sS --max-time "$timeout" "$UNI_RAW_URL" 2>/dev/null) || return 1
    latest_ver=$(printf '%s\n' "$raw_script" | sed -n 's/^UNI_VERSION="\([^"]*\)".*/\1/p' | head -n1)
    [[ -n "$latest_ver" ]] || return 2

    echo "$latest_ver"
}

# ── Update notifier ──────────────────────────────────────────
# Runs a background check once per day. If a newer version is found,
# prints a banner at the end of the current command.
_UPDATE_BANNER=""

check_for_update() {
    mkdir -p "$UNI_CACHE_DIR"
    local cache_file="$UNI_CACHE_DIR/latest_version.txt"
    local now
    now=$(date +%s)

    # Refresh cache if stale
    local cached_age=99999
    if [[ -f "$cache_file" ]]; then
        cached_age=$(( now - $(stat -c %Y "$cache_file" 2>/dev/null || echo 0) ))
    fi

    if (( cached_age >= UNI_UPDATE_CHECK_TTL )); then
        # Background fetch — doesn't block the user
        {
            local latest
            latest=$(fetch_uni_latest_version 6 2>/dev/null || true)
            [[ -n "$latest" ]] && echo "$latest" > "$cache_file"
        } &
        disown $! 2>/dev/null || true
        return
    fi

    # Read cached version and compare
    local latest_ver
    latest_ver=$(cat "$cache_file" 2>/dev/null | tr -d '[:space:]')
    [[ -z "$latest_ver" ]] && return

    if version_gt "$latest_ver" "$UNI_VERSION"; then
        _UPDATE_BANNER="${YELLOW}${BOLD}  ╔══════════════════════════════════════════╗
  ║  uni ${latest_ver} is available  (you have ${UNI_VERSION})  ║
  ║  Run: uni self-update                    ║
  ╚══════════════════════════════════════════╝${RESET}"
    fi
}

print_update_banner() {
    [[ -n "$_UPDATE_BANNER" ]] && echo -e "\n$_UPDATE_BANNER"
}

# ── GitHub integration ───────────────────────────────────────
parse_github_repo() {
    local input="$1"
    if [[ "$input" =~ ^https?://github\.com/([^/]+/[^/]+) ]]; then
        echo "${BASH_REMATCH[1]}" | sed 's|/releases.*||; s|\.git$||'
    elif [[ "$input" =~ ^([a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+)$ ]]; then
        echo "$input"
    else
        echo ""
    fi
}

gh_release_json() {
    local repo="$1"
    curl -sf --max-time 10 \
        -H "Accept: application/vnd.github+json" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        "https://api.github.com/repos/${repo}/releases/latest" 2>/dev/null
}

# Score an asset name — higher = better match for this system
score_asset() {
    local name="${1,,}"
    local score=0

    for pat in $(arch_patterns); do
        if [[ "$name" == *"${pat,,}"* ]]; then
            score=$((score + 50)); break
        fi
    done

    local other_arches="x86_64 amd64 x64 aarch64 arm64 armv7l armhf i386 i686"
    for pat in $other_arches; do
        local is_ours=0
        for mine in $(arch_patterns); do
            [[ "${pat,,}" == "${mine,,}" ]] && is_ours=1 && break
        done
        [[ $is_ours -eq 1 ]] && continue
        [[ "$name" == *"${pat,,}"* ]] && score=$((score - 200))
    done

    [[ "$name" == *.deb      ]] && score=$((score + 40))
    [[ "$name" == *.appimage ]] && score=$((score + 30))
    [[ "$name" == *.tar.gz   ]] && score=$((score + 10))
    [[ "$name" == *.tar.xz   ]] && score=$((score + 10))
    [[ "$name" == *.zip      ]] && score=$((score + 5))
    [[ "$name" == *linux*    ]] && score=$((score + 20))
    [[ "$name" == *.rpm      ]] && score=$((score - 100))
    [[ "$name" == *.sha256   ]] && score=$((score - 500))
    [[ "$name" == *.sha512   ]] && score=$((score - 500))
    [[ "$name" == *.asc      ]] && score=$((score - 500))
    [[ "$name" == *source*   ]] && score=$((score - 100))
    [[ "$name" == *debug*    ]] && score=$((score - 100))
    [[ "$name" == *.exe      ]] && score=$((score - 300))
    [[ "$name" == *.dmg      ]] && score=$((score - 300))
    [[ "$name" == *windows*  ]] && score=$((score - 300))
    [[ "$name" == *darwin*   ]] && score=$((score - 300))
    [[ "$name" == *macos*    ]] && score=$((score - 300))

    echo "$score"
}

pick_best_asset() {
    local json="$1"
    python3 - "$json" << 'PYEOF'
import json, sys
data = json.loads(sys.argv[1])
assets = data.get('assets', [])
if not assets:
    sys.exit(1)
for a in assets:
    print(f"{a['browser_download_url']}\t{a['name']}")
PYEOF
}

install_from_github() {
    local repo="$1"

    header "GitHub  →  ${repo}"
    spin_start "Fetching latest release..."
    local json
    json=$(gh_release_json "$repo")
    spin_stop

    [[ -z "$json" ]] && die "Could not fetch release info for ${repo}. Check the repo name and your connection."

    local tag
    tag=$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d.get('tag_name','unknown'))" "$json" 2>/dev/null || echo "unknown")
    info "Latest release: ${BOLD}${tag}${RESET}"

    local asset_lines
    asset_lines=$(pick_best_asset "$json") || die "No release assets found for ${repo}."

    local best_url="" best_name="" best_score=-9999
    local all_urls=() all_names=()
    while IFS=$'\t' read -r url name; do
        all_urls+=("$url")
        all_names+=("$name")
        local s
        s=$(score_asset "$name")
        if (( s > best_score )); then
            best_score=$s
            best_url="$url"
            best_name="$name"
        fi
    done <<< "$asset_lines"

    if (( best_score < 0 )) || [[ -z "$best_url" ]]; then
        warn "Could not auto-detect asset for $(uname -m). Please select:"
        echo ""
        local i=1
        for name in "${all_names[@]}"; do
            echo -e "  ${BOLD}${i})${RESET} ${name}"
            ((i++))
        done
        echo ""
        local choice
        read -rp "$(echo -e "${CYAN}${BOLD}Select asset [1-${#all_names[@]}]:${RESET} ")" choice
        local idx=$(( choice - 1 ))
        best_url="${all_urls[$idx]}"
        best_name="${all_names[$idx]}"
    else
        echo ""
        local i=1
        for name in "${all_names[@]}"; do
            if [[ "$name" == "$best_name" ]]; then
                echo -e "  ${GREEN}${BOLD}${i})${RESET} ${GREEN}${name}${RESET}  ${DIM}← auto-selected${RESET}"
            else
                echo -e "  ${DIM}${i}) ${name}${RESET}"
            fi
            ((i++))
        done
        echo ""
        local choice
        read -rp "$(echo -e "${CYAN}${BOLD}Press Enter to confirm, or pick another [1-${#all_names[@]}]:${RESET} ")" choice
        if [[ -n "$choice" && "$choice" =~ ^[0-9]+$ ]]; then
            local idx=$(( choice - 1 ))
            if (( idx >= 0 && idx < ${#all_names[@]} )); then
                best_url="${all_urls[$idx]}"
                best_name="${all_names[$idx]}"
            fi
        fi
    fi

    info "Downloading ${BOLD}${best_name}${RESET}..."
    has_aria2c && info "${DIM}Using aria2c (parallel connections)${RESET}"
    local lower="${best_name,,}"

    if [[ "$lower" == *.deb ]]; then
        local tmp_deb
        tmp_deb=$(mktemp --suffix=.deb)
        download_file "$best_url" "$tmp_deb" || { rm -f "$tmp_deb"; die "Download failed."; }
        install_deb "$tmp_deb"
        rm -f "$tmp_deb"
    elif [[ "$lower" == *.appimage ]]; then
        install_appimage "$best_url"
    elif [[ "$lower" == *.tar.gz || "$lower" == *.tar.xz || "$lower" == *.zip ]]; then
        install_archive "$best_url" "$best_name" "$repo"
    else
        die "Unsupported asset type: ${best_name}\nDownload manually: ${best_url}"
    fi
}

# ── Install binary from archive ──────────────────────────────
install_archive() {
    local url="$1" filename="$2" repo="$3"
    local pkg_name
    pkg_name=$(basename "$repo")

    local tmpdir
    tmpdir=$(mktemp -d)
    download_file "$url" "$tmpdir/$filename" || { rm -rf "$tmpdir"; die "Download failed."; }

    step "Extracting..."
    if [[ "$filename" == *.zip ]]; then
        command -v unzip &>/dev/null || { rm -rf "$tmpdir"; die "unzip required: sudo apt install unzip"; }
        unzip -q "$tmpdir/$filename" -d "$tmpdir/extracted"
    else
        mkdir -p "$tmpdir/extracted"
        tar -xf "$tmpdir/$filename" -C "$tmpdir/extracted"
    fi

    local bins=()
    while IFS= read -r -d '' f; do
        bins+=("$f")
    done < <(find "$tmpdir/extracted" -maxdepth 3 -type f -executable \
        -not -name "*.so" -not -name "*.sh" -print0 2>/dev/null)

    [[ ${#bins[@]} -eq 0 ]] && { rm -rf "$tmpdir"; die "No executable found in archive."; }

    local chosen_bin="${bins[0]}"
    if [[ ${#bins[@]} -gt 1 ]]; then
        echo ""
        header "Multiple executables found"
        local i=1
        for b in "${bins[@]}"; do
            echo -e "  ${BOLD}${i})${RESET} $(basename "$b")  ${DIM}${b}${RESET}"
            ((i++))
        done
        echo ""
        local choice
        read -rp "$(echo -e "${CYAN}${BOLD}Which to install? [1-${#bins[@]}]:${RESET} ")" choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#bins[@]} )); then
            chosen_bin="${bins[$((choice-1))]}"
        fi
    fi

    local install_dir="$REAL_HOME/.local/bin"
    mkdir -p "$install_dir" || die "Could not create ${install_dir}"
    local bin_name
    bin_name=$(basename "$chosen_bin")
    cp "$chosen_bin" "$install_dir/$bin_name" \
        || { rm -rf "$tmpdir"; die "Could not copy binary to ${install_dir}"; }
    chmod +x "$install_dir/$bin_name" \
        || { rm -rf "$tmpdir"; die "Could not set executable bit on ${install_dir}/${bin_name}"; }
    rm -rf "$tmpdir"

    registry_add "$pkg_name" "archive" "$install_dir/$bin_name"
    success "Installed ${BOLD}${bin_name}${RESET} → ${install_dir}/${bin_name}"

    if [[ ":$PATH:" != *":$install_dir:"* ]]; then
        warn "~/.local/bin is not in PATH. Add to ~/.bashrc or ~/.zshrc:"
        echo -e "  ${DIM}export PATH=\"\$HOME/.local/bin:\$PATH\"${RESET}"
    fi
}

# ── Search functions ─────────────────────────────────────────
search_apt() {
    command -v apt-cache &>/dev/null || return 1
    local candidate
    candidate=$(apt-cache policy "$1" 2>/dev/null | awk '/Candidate:/{print $2}')
    [[ -n "$candidate" && "$candidate" != "(none)" ]] && echo "apt"
}

search_flatpak() {
    has_flatpak && flatpak search --columns=application "$1" 2>/dev/null | grep -qi "$1" && echo "flatpak"
}

search_snap() {
    has_snap && snap find "$1" 2>/dev/null | grep -qi "$1" && echo "snap"
}

search_github() {
    local pkg="$1"
    local cache_file="$UNI_CACHE_DIR/gh_search_${pkg}.txt"

    if [[ -f "$cache_file" ]]; then
        local age=$(( $(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || echo 0) ))
        if (( age < UNI_CACHE_TTL )); then
            local cached
            cached=$(cat "$cache_file")
            [[ -n "$cached" ]] && { echo "$cached"; return 0; } || return 1
        fi
    fi

    local json
    json=$(curl -sf --max-time 8 \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/search/repositories?q=${pkg}+in:name&sort=stars&per_page=5" 2>/dev/null) || return 1
    [[ -z "$json" ]] && return 1

    local result
    result=$(python3 - "$json" "$pkg" << 'PYEOF'
import json, sys
data = json.loads(sys.argv[1])
query = sys.argv[2].lower()
items = data.get('items', [])
if not items:
    sys.exit(1)
for item in items:
    if item['name'].lower() == query:
        print(item['full_name'])
        sys.exit(0)
print(items[0]['full_name'])
PYEOF
) || return 1

    mkdir -p "$UNI_CACHE_DIR"
    echo "$result" > "$cache_file"
    echo "$result"
}

# ── Parallel search ──────────────────────────────────────────
parallel_search() {
    local pkg="$1"
    local tmp
    tmp=$(mktemp -d)

    search_apt     "$pkg" > "$tmp/apt"     2>/dev/null &
    local pid_apt=$!
    search_flatpak "$pkg" > "$tmp/flatpak" 2>/dev/null &
    local pid_flatpak=$!
    search_snap    "$pkg" > "$tmp/snap"    2>/dev/null &
    local pid_snap=$!
    search_github  "$pkg" > "$tmp/gh"      2>/dev/null &
    local pid_gh=$!

    spin_start "Searching all sources in parallel..."
    wait $pid_apt $pid_flatpak $pid_snap $pid_gh
    spin_stop

    apt_result=$(cat "$tmp/apt"     2>/dev/null || true)
    flatpak_result=$(cat "$tmp/flatpak" 2>/dev/null || true)
    snap_result=$(cat "$tmp/snap"   2>/dev/null || true)
    gh_result=$(cat "$tmp/gh"       2>/dev/null || true)

    rm -rf "$tmp"
}

# ── Single-source search (for --source flag) ─────────────────
single_source_search() {
    local pkg="$1" source="$2"
    apt_result="" flatpak_result="" snap_result="" gh_result=""
    case "$source" in
        apt)
            spin_start "Searching apt..."
            apt_result=$(search_apt "$pkg" 2>/dev/null) || true
            spin_stop
            ;;
        flatpak)
            spin_start "Searching flatpak..."
            flatpak_result=$(search_flatpak "$pkg" 2>/dev/null) || true
            spin_stop
            ;;
        snap)
            spin_start "Searching snap..."
            snap_result=$(search_snap "$pkg" 2>/dev/null) || true
            spin_stop
            ;;
        github|gh)
            spin_start "Searching GitHub..."
            gh_result=$(search_github "$pkg" 2>/dev/null) || true
            spin_stop
            ;;
        *)
            die "Unknown source '${source}'. Valid: apt, flatpak, snap, github"
            ;;
    esac
}

# ── AppImage helpers ─────────────────────────────────────────
install_appimage() {
    local src="$1"
    local name

    if [[ "$src" =~ ^https?:// ]]; then
        name=$(basename "$src" | sed 's/\.AppImage$//i; s/\.appimage$//i')
        info "Downloading AppImage..."
        has_aria2c && info "${DIM}Using aria2c (parallel connections)${RESET}"
        download_file "$src" "$UNI_APPIMAGE_DIR/${name}.AppImage" \
            || die "Failed to download AppImage"
        src="$UNI_APPIMAGE_DIR/${name}.AppImage"
    else
        [[ -f "$src" ]] || die "File not found: $src"
        name=$(basename "$src" | sed 's/\.AppImage$//i; s/\.appimage$//i')
        cp "$src" "$UNI_APPIMAGE_DIR/${name}.AppImage"
    fi

    chmod +x "$UNI_APPIMAGE_DIR/${name}.AppImage"

    local icon_path=""
    step "Extracting icon..."
    local tmpdir
    tmpdir=$(mktemp -d)
    pushd "$tmpdir" &>/dev/null || die "mktemp failed"

    if "$UNI_APPIMAGE_DIR/${name}.AppImage" --appimage-extract &>/dev/null; then
        local extracted_icon
        extracted_icon=$(find squashfs-root -name "*.png" -o -name "*.svg" 2>/dev/null \
            | xargs ls -S 2>/dev/null | head -1)
        if [[ -n "$extracted_icon" ]]; then
            local icon_ext="${extracted_icon##*.}"
            cp "$extracted_icon" "$UNI_ICON_DIR/${name}.${icon_ext}"
            icon_path="$UNI_ICON_DIR/${name}.${icon_ext}"
        fi
    fi
    popd &>/dev/null || true
    rm -rf "$tmpdir"

    [[ -z "$icon_path" ]] && icon_path="application-x-executable"

    cat > "$UNI_DESKTOP_DIR/${name}.desktop" <<EOF
[Desktop Entry]
Name=${name}
Exec=$UNI_APPIMAGE_DIR/${name}.AppImage
Icon=${icon_path}
Type=Application
Categories=Utility;
Comment=Installed via uni
EOF

    registry_add "$name" "appimage" "$UNI_APPIMAGE_DIR/${name}.AppImage"
    success "AppImage installed: ${BOLD}${name}${RESET}"
    success "Desktop entry: ${UNI_DESKTOP_DIR}/${name}.desktop"
}

remove_appimage() {
    local name="$1"
    local appimage_path
    appimage_path=$(registry_get "$name" "id")

    if [[ -f "$appimage_path" ]]; then
        rm -f "$appimage_path" || die "Could not remove AppImage: ${appimage_path}"
        success "Removed AppImage: ${appimage_path}"
    else
        warn "AppImage not found at recorded path: ${appimage_path}"
    fi

    if [[ -f "$UNI_DESKTOP_DIR/${name}.desktop" ]]; then
        rm -f "$UNI_DESKTOP_DIR/${name}.desktop" \
            && success "Removed desktop entry" \
            || warn "Could not remove desktop entry"
    fi

    for ext in png svg; do
        local icon="$UNI_ICON_DIR/${name}.${ext}"
        [[ -f "$icon" ]] && rm -f "$icon"
    done

    registry_remove "$name"
}

# ── Install deb ──────────────────────────────────────────────
install_deb() {
    local file="$1"
    [[ -f "$file" ]] || die "File not found: $file"

    local deb_arch sys
    deb_arch=$(dpkg-deb --field "$file" Architecture 2>/dev/null || true)
    sys=$(sys_arch)
    if [[ -n "$deb_arch" && "$deb_arch" != "all" && "$deb_arch" != "$sys" ]]; then
        spin_stop
        die "Architecture mismatch: package is ${BOLD}${deb_arch}${RESET} but system is ${BOLD}${sys}${RESET}.\nDownload the ${sys} build instead."
    fi

    local name
    name=$(dpkg-deb --field "$file" Package 2>/dev/null || basename "$file" .deb)
    info "Installing .deb: ${BOLD}${name}${RESET}"

    if sudo dpkg -i "$file"; then
        registry_add "$name" "dpkg" "$name"
        success "Installed ${BOLD}${name}${RESET} via dpkg"
    else
        warn "dpkg errors — fixing dependencies..."
        sudo "$(apt_cmd)" -f install -y \
            || die "Dependency fix failed for ${BOLD}${name}${RESET}. Run: sudo apt -f install"
        if dpkg -s "$name" 2>/dev/null | grep -q "^Status: install ok installed"; then
            registry_add "$name" "dpkg" "$name"
            success "Installed ${BOLD}${name}${RESET} via dpkg (after fix)"
        else
            die "Installation of ${BOLD}${name}${RESET} failed even after dependency fix."
        fi
    fi
}

# ── Installed detection ──────────────────────────────────────
is_installed_apt() {
    dpkg -s "$1" &>/dev/null && dpkg -s "$1" 2>/dev/null | grep -q "^Status: install ok installed"
}

is_installed_flatpak() {
    has_flatpak && flatpak list --columns=application,name 2>/dev/null | grep -qi "$1"
}

is_installed_snap() {
    has_snap && snap list "$1" &>/dev/null
}

# ── Post-install / post-remove verification ──────────────────
verify_apt_installed() {
    local pkg="$1"
    is_installed_apt "$pkg" \
        || die "Installation of ${BOLD}${pkg}${RESET} failed — package not found after install."
}

verify_apt_removed() {
    local pkg="$1"
    is_installed_apt "$pkg" \
        && die "Removal of ${BOLD}${pkg}${RESET} failed — package still installed after remove."
    return 0
}

UNI_INSTALLED_IN=()
detect_installed_backends() {
    local pkg="$1"
    UNI_INSTALLED_IN=()
    { is_installed_apt     "$pkg" && UNI_INSTALLED_IN+=("apt");     } 2>/dev/null || true
    { is_installed_flatpak "$pkg" && UNI_INSTALLED_IN+=("flatpak"); } 2>/dev/null || true
    { is_installed_snap    "$pkg" && UNI_INSTALLED_IN+=("snap");    } 2>/dev/null || true
    local reg_backend
    reg_backend=$(registry_get "$pkg" "backend") || true
    if [[ -n "$reg_backend" ]] && ! in_array "$reg_backend" "${UNI_INSTALLED_IN[@]:-}"; then
        UNI_INSTALLED_IN+=("${reg_backend}(uni)")
    fi
}

# ── Already-installed prompt ─────────────────────────────────
UNI_DECISION=""
handle_already_installed() {
    local pkg="$1"; shift
    local installed_str
    installed_str=$(IFS=', '; echo "$*")

    echo ""
    echo -e "${YELLOW}${BOLD} ⚠  ${pkg}${RESET}${YELLOW} already installed${RESET} via ${BOLD}${installed_str}${RESET}"
    divider

    PS3="$(echo -e "${CYAN}${BOLD}What to do?${RESET} [1-3]: ")"
    select _ in "Reinstall / refresh" "Install from a different source" "Exit — keep as is"; do
        case "$REPLY" in
            1) UNI_DECISION="reinstall"; break ;;
            2) UNI_DECISION="alongside"; break ;;
            3) UNI_DECISION="exit";      break ;;
            *) warn "Enter 1, 2, or 3." ;;
        esac
    done
}

# ── Source selection menu ────────────────────────────────────
select_source() {
    local pkg="$1"; shift
    echo "" >&2
    echo -e "${BOLD}${BLUE}${pkg}${RESET} found in multiple sources:" >&2
    divider >&2
    PS3="$(echo -e "${CYAN}${BOLD}Select source${RESET} [1-$#]: ")"
    local chosen
    select chosen in "$@"; do
        if [[ -n "$chosen" ]]; then
            echo "$chosen"
            return
        fi
        warn "Invalid choice." >&2
    done
}

# ── Resolve flatpak App ID ───────────────────────────────────
resolve_flatpak_id() {
    local pkg="$1"
    [[ "$pkg" == *.*.* ]] && { echo "$pkg"; return 0; }

    local results
    results=$(flatpak search --columns=application,name "$pkg" 2>/dev/null) || true
    [[ -z "$results" ]] && return 1

    local filtered
    filtered=$(echo "$results" | grep -iv "plugin\|runtime\|extension" | grep -i "$pkg") || true
    [[ -z "$filtered" ]] && filtered=$(echo "$results" | grep -i "$pkg")
    [[ -z "$filtered" ]] && return 1

    local exact
    exact=$(echo "$filtered" | awk -F'\t' -v p="${pkg,,}" 'tolower($2)==p{print $1}' | head -1)
    [[ -n "$exact" ]] && { echo "$exact"; return 0; }

    local id_match
    id_match=$(echo "$filtered" | awk -F'\t' -v p="${pkg,,}" 'tolower($1)~("\\."p"$"){print $1}' | head -1)
    [[ -n "$id_match" ]] && { echo "$id_match"; return 0; }

    local ids=() names=()
    while IFS=$'\t' read -r appid appname _; do
        [[ -z "$appid" ]] && continue
        ids+=("$appid")
        names+=("${appname:-$appid}")
    done <<< "$filtered"
    [[ ${#ids[@]} -eq 1 ]] && { echo "${ids[0]}"; return 0; }

    echo "" >&2
    echo -e "${BOLD}${BLUE}Multiple flatpak matches for '${pkg}':${RESET}" >&2
    divider >&2
    PS3="$(echo -e "${CYAN}${BOLD}Select:${RESET} ")"
    local fchoice
    select fchoice in "${names[@]}"; do
        [[ -n "$fchoice" ]] && { echo "${ids[$((REPLY-1))]}"; return 0; }
        warn "Invalid choice." >&2
    done
}

# ── apt parallel-download install ────────────────────────────
do_apt_install_many() {
    local pkgs=("$@")
    [[ ${#pkgs[@]} -eq 0 ]] && return 0

    if has_aria2c; then
        step "Resolving download URLs via apt..."
        local urls
        urls=$(apt-get install --print-uris -qq "${pkgs[@]}" 2>/dev/null \
            | grep -oP "(?<=')[^']+" | grep -E '\.deb$') || true

        if [[ -n "$urls" ]]; then
            local tmpdir
            tmpdir=$(mktemp -d)
            step "Downloading packages in parallel (aria2c)..."
            echo "$urls" | aria2c \
                --input-file=- \
                -d "$tmpdir" \
                -j 8 \
                --console-log-level=warn \
                --summary-interval=0 \
                --allow-overwrite=true 2>/dev/null

            local debs=()
            while IFS= read -r -d '' f; do
                debs+=("$f")
            done < <(find "$tmpdir" -name "*.deb" -print0 2>/dev/null)

            if [[ ${#debs[@]} -gt 0 ]]; then
                sudo dpkg -i "${debs[@]}" 2>/dev/null || true
                sudo "$(apt_cmd)" -f install -y
                local rc=$?
                rm -rf "$tmpdir"
                return $rc
            fi
            rm -rf "$tmpdir"
            # aria2c path produced no debs — fall through to regular apt
        fi
    fi

    sudo "$(apt_cmd)" install -y "${pkgs[@]}"
    return $?
}

do_apt_install() {
    local pkg="$1"
    do_apt_install_many "$pkg"
}

install_many_github_parallel() {
    local repos=("$@")
    local tmpdir
    tmpdir=$(mktemp -d)

    local pids=() names=() logs=()
    local pkg safe_name log
    local n=0

    for pkg in "${repos[@]}"; do
        ((n++))
        safe_name=$(printf '%s' "$pkg" | tr -c '[:alnum:]_.:-' '_')
        log="${tmpdir}/${n}_${safe_name}.log"
        (
            cmd_install_one "$pkg" "github"
        ) >"$log" 2>&1 &
        pids+=("$!")
        names+=("$pkg")
        logs+=("$log")
    done

    local idx=0
    local rc=0
    while (( idx < ${#pids[@]} )); do
        if wait "${pids[$idx]}"; then
            success "Installed ${BOLD}${names[$idx]}${RESET} via GitHub"
        else
            error "Failed to install ${names[$idx]} via GitHub"
            sed 's/^/  /' "${logs[$idx]}" | head -n 120
            rc=1
        fi
        ((idx++))
    done

    rm -rf "$tmpdir"
    return "$rc"
}

# ── Install executor ─────────────────────────────────────────
do_install() {
    local pkg="$1" chosen_source="$2"
    case "$chosen_source" in
        apt)
            do_apt_install "$pkg" || die "Failed to install ${BOLD}${pkg}${RESET} via $(apt_cmd)."
            verify_apt_installed "$pkg"
            registry_add "$pkg" "apt" "$pkg"
            success "Installed ${BOLD}${pkg}${RESET} via $(apt_cmd)"
            ;;
        flatpak)
            local appid
            appid=$(resolve_flatpak_id "$pkg")
            [[ -z "$appid" ]] && die "Could not resolve flatpak ID for '${pkg}'"
            flatpak install --noninteractive -y --or-update "$appid" \
                || die "Failed to install flatpak ${appid}"
            registry_add "$pkg" "flatpak" "$appid"
            success "Installed ${BOLD}${pkg}${RESET} via flatpak (${appid})"
            ;;
        snap)
            sudo snap install "$pkg" || die "Failed to install snap ${pkg}"
            registry_add "$pkg" "snap" "$pkg"
            success "Installed ${BOLD}${pkg}${RESET} via snap"
            ;;
    esac
}

# ── INSTALL ──────────────────────────────────────────────────
GH_REPO=""
cmd_install_one() {
    local pkg="$1"
    local forced_source="${2:-}"

    # JSON event correlation: die() uses UNI_JSON_PKG to emit done/error events.
    UNI_JSON_PKG="$pkg"
    emit_event "$pkg" "resolving"

    # GitHub URL or user/repo shorthand
    local maybe_repo
    maybe_repo=$(parse_github_repo "$pkg")
    if [[ -n "$maybe_repo" ]]; then
        GH_REPO="$maybe_repo"
        emit_event "$pkg" "downloading" "backend=github" "source=$GH_REPO"
        install_from_github "$GH_REPO"
        emit_event "$pkg" "done" "success=true" "backend=github"
        return
    fi

    # Local or remote .deb
    if [[ "$pkg" == *.deb ]]; then
        if [[ "$pkg" =~ ^https?:// ]]; then
            local tmp_deb
            tmp_deb=$(mktemp --suffix=.deb)
            info "Downloading .deb..."
            has_aria2c && info "${DIM}Using aria2c (parallel connections)${RESET}"
            download_file "$pkg" "$tmp_deb" || { rm -f "$tmp_deb"; die "Download failed."; }
            install_deb "$tmp_deb"
            rm -f "$tmp_deb"
        else
            install_deb "$pkg"
        fi
        return
    fi

    # AppImage
    if [[ "$pkg" == *.AppImage || "$pkg" == *.appimage ]] || \
       [[ "$pkg" =~ ^https?://.+\.(AppImage|appimage)$ ]]; then
        install_appimage "$pkg"; return
    fi

    # Check already installed (skip if --source is forcing a specific backend)
    if [[ -z "$forced_source" ]]; then
        spin_start "Checking existing installations..."
        detect_installed_backends "$pkg"
        spin_stop
    fi

    local exclude_sources=()

    if [[ -z "$forced_source" && ${#UNI_INSTALLED_IN[@]} -gt 0 ]]; then
        handle_already_installed "$pkg" "${UNI_INSTALLED_IN[@]}"
        case "$UNI_DECISION" in
            exit)
                info "Nothing changed."
                return 0
                ;;
            reinstall)
                local pb="${UNI_INSTALLED_IN[0]}"
                pb="${pb%(uni)}"
                info "Reinstalling ${BOLD}${pkg}${RESET} from ${pb}..."
                case "$pb" in
                    apt)
                        do_apt_install "$pkg" --reinstall 2>/dev/null \
                            || sudo "$(apt_cmd)" install --reinstall -y "$pkg"
                        registry_add "$pkg" "apt" "$pkg"
                        success "Reinstalled ${BOLD}${pkg}${RESET}"
                        ;;
                    flatpak)
                        local appid
                        appid=$(registry_get "$pkg" "id")
                        [[ -z "$appid" ]] && appid=$(resolve_flatpak_id "$pkg")
                        flatpak update --noninteractive -y "$appid" || \
                            flatpak install --noninteractive -y "$appid"
                        registry_add "$pkg" "flatpak" "$appid"
                        success "Reinstalled ${BOLD}${pkg}${RESET}"
                        ;;
                    snap)
                        sudo snap refresh "$pkg" || sudo snap install "$pkg"
                        registry_add "$pkg" "snap" "$pkg"
                        success "Reinstalled ${BOLD}${pkg}${RESET}"
                        ;;
                    dpkg|archive|appimage)
                        warn "Re-run: uni install <url-or-file> to reinstall this package."
                        ;;
                esac
                return 0
                ;;
            alongside)
                for b in "${UNI_INSTALLED_IN[@]}"; do
                    exclude_sources+=("${b%(uni)}")
                done
                info "Searching other sources (excluding: ${exclude_sources[*]})..."
                ;;
        esac
    fi

    # Search — either single forced source or parallel across all
    local apt_result="" flatpak_result="" snap_result="" gh_result=""
    if [[ -n "$forced_source" ]]; then
        info "Searching ${BOLD}${forced_source}${RESET} only (--source)..."
        single_source_search "$pkg" "$forced_source"
    else
        parallel_search "$pkg"
    fi

    local sources=()
    [[ -n "$apt_result"     ]] && ! in_array "apt"     "${exclude_sources[@]:-}" && sources+=("apt")
    [[ -n "$flatpak_result" ]] && ! in_array "flatpak" "${exclude_sources[@]:-}" && sources+=("flatpak")
    [[ -n "$snap_result"    ]] && ! in_array "snap"    "${exclude_sources[@]:-}" && sources+=("snap")
    [[ -n "$gh_result"      ]] && sources+=("github (${gh_result})")

    if [[ ${#sources[@]} -eq 0 ]]; then
        if [[ -n "$forced_source" ]]; then
            die "Package '${pkg}' not found in ${forced_source}."
        elif [[ ${#exclude_sources[@]} -gt 0 ]]; then
            warn "No other sources found for '${pkg}'."
        else
            warn "Package '${pkg}' not found in apt, flatpak, snap, or GitHub."
            echo -e "  ${DIM}Try: uni install user/repo  |  uni install <url.deb>  |  uni install <url.AppImage>${RESET}"
        fi
        exit 1
    fi

    local chosen_source
    if [[ ${#sources[@]} -eq 1 ]]; then
        chosen_source="${sources[0]}"
        info "Found in ${BOLD}${chosen_source}${RESET}"
    else
        chosen_source=$(select_source "$pkg" "${sources[@]}")
    fi

    if [[ "$chosen_source" == github* ]]; then
        GH_REPO="$gh_result"
        emit_event "$pkg" "downloading" "backend=github" "source=$GH_REPO"
        install_from_github "$GH_REPO"
        emit_event "$pkg" "done" "success=true" "backend=github"
    else
        emit_event "$pkg" "downloading" "backend=$chosen_source"
        emit_event "$pkg" "installing" "backend=$chosen_source"
        do_install "$pkg" "$chosen_source"
        emit_event "$pkg" "done" "success=true" "backend=$chosen_source"
    fi
}

cmd_install() {
    # Parse flags: uni install <pkg...> [--source apt|flatpak|snap|github] [--parallel] [--json]
    local forced_source=""
    local install_parallel=0
    local pkgs=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --source|-s)
                shift
                forced_source="${1:-}"
                [[ -z "$forced_source" ]] && die "--source requires a value: apt, flatpak, snap, github"
                shift
                ;;
            --source=*)
                forced_source="${1#*=}"
                [[ -z "$forced_source" ]] && die "--source requires a value: apt, flatpak, snap, github"
                shift
                ;;
            --parallel|-p)
                install_parallel=1
                shift
                ;;
            --json)
                UNI_JSON=1
                shift
                ;;
            *)
                pkgs+=("$1")
                shift
                ;;
        esac
    done

    forced_source="${forced_source,,}"
    [[ ${#pkgs[@]} -eq 0 ]] && die "Usage: uni install <package...|user/repo|github-url|file.deb|file.appimage|url> [--source apt|flatpak|snap|github]"

    init_registry

    local total="${#pkgs[@]}"
    local pkg

    # Batch apt installs in one transaction when source is explicitly apt.
    if (( total > 1 )) && [[ "$forced_source" == "apt" ]]; then
        info "Installing (${total}) packages via ${BOLD}apt${RESET} in one batch..."
        do_apt_install_many "${pkgs[@]}" || die "Batch apt install failed."
        local any_failed=0
        for pkg in "${pkgs[@]}"; do
            if is_installed_apt "$pkg"; then
                registry_add "$pkg" "apt" "$pkg"
                success "Installed ${BOLD}${pkg}${RESET} via $(apt_cmd)"
            else
                error "Failed to install ${BOLD}${pkg}${RESET} — not found after apt run."
                any_failed=1
            fi
        done
        [[ $any_failed -eq 1 ]] && exit 1
        return
    fi

    if (( total > 1 )) && (( install_parallel == 1 )); then
        case "$forced_source" in
            github|gh)
                info "Installing (${total}) GitHub packages in parallel..."
                install_many_github_parallel "${pkgs[@]}"
                return $?
                ;;
            "")
                die "--parallel for multiple packages requires --source github (or use --source apt for batched apt installs)."
                ;;
            *)
                warn "--parallel is currently supported for --source github only; running sequentially for ${forced_source}."
                ;;
        esac
    fi

    local i=0
    for pkg in "${pkgs[@]}"; do
        ((i++))
        if (( total > 1 )); then
            info "Installing (${i}/${total}): ${BOLD}${pkg}${RESET}"
        fi
        cmd_install_one "$pkg" "$forced_source"
    done
}

# ── REMOVE ───────────────────────────────────────────────────
cmd_remove() {
    local pkg="${1:-}"
    [[ -z "$pkg" ]] && die "Usage: uni remove <package>"
    init_registry

    local backend id
    backend=$(registry_get "$pkg" "backend")
    id=$(registry_get "$pkg" "id")

    if [[ -z "$backend" ]]; then
        warn "'${pkg}' not in uni registry — trying all backends..."
        if is_installed_apt "$pkg"; then
            sudo "$(apt_cmd)" remove -y "$pkg" || die "apt remove failed for ${BOLD}${pkg}${RESET}."
            verify_apt_removed "$pkg"
            success "Removed ${BOLD}${pkg}${RESET}"
        elif is_installed_flatpak "$pkg"; then
            local appid
            appid=$(flatpak list --columns=application,name 2>/dev/null | grep -i "$pkg" | head -1 | awk '{print $1}')
            if [[ -n "$appid" ]]; then
                flatpak uninstall --noninteractive -y "$appid" \
                    || die "flatpak uninstall failed for ${BOLD}${pkg}${RESET}."
            else
                flatpak uninstall -y "$pkg" \
                    || die "flatpak uninstall failed for ${BOLD}${pkg}${RESET}."
            fi
            success "Removed ${BOLD}${pkg}${RESET}"
        elif is_installed_snap "$pkg"; then
            sudo snap remove "$pkg" || die "snap remove failed for ${BOLD}${pkg}${RESET}."
            success "Removed ${BOLD}${pkg}${RESET}"
        else
            die "'${pkg}' not found in any backend."
        fi
        return
    fi

    info "Removing ${BOLD}${pkg}${RESET} [${backend}]..."

    case "$backend" in
        apt)
            sudo "$(apt_cmd)" remove -y "$id" || die "apt remove failed for ${BOLD}${pkg}${RESET}."
            verify_apt_removed "$id"
            ;;
        dpkg)
            sudo dpkg -r "$id" || sudo "$(apt_cmd)" remove -y "$id" \
                || die "Failed to remove ${BOLD}${pkg}${RESET}."
            verify_apt_removed "$id"
            ;;
        flatpak)
            flatpak uninstall --noninteractive -y "$id" \
                || die "flatpak uninstall failed for ${BOLD}${pkg}${RESET}."
            ;;
        snap)
            sudo snap remove "$id" \
                || die "snap remove failed for ${BOLD}${pkg}${RESET}."
            ;;
        appimage) remove_appimage "$pkg"; return ;;
        archive)
            if [[ -f "$id" ]]; then
                rm -f "$id" || die "Could not remove binary: ${id}"
                success "Removed binary: ${id}"
            else
                warn "Binary not found at recorded path: ${id}"
            fi
            registry_remove "$pkg"; return
            ;;
    esac

    registry_remove "$pkg"
    success "Removed ${BOLD}${pkg}${RESET}"
}

# ── PURGE ────────────────────────────────────────────────────
cmd_purge() {
    local pkg="${1:-}"
    [[ -z "$pkg" ]] && die "Usage: uni purge <package>"
    init_registry

    local backend id
    backend=$(registry_get "$pkg" "backend")
    id=$(registry_get "$pkg" "id")

    if [[ -z "$backend" ]]; then
        warn "'${pkg}' not in uni registry — trying all backends..."
        if is_installed_apt "$pkg"; then
            sudo "$(apt_cmd)" purge -y "$pkg" || die "apt purge failed for ${BOLD}${pkg}${RESET}."
            verify_apt_removed "$pkg"
            sudo "$(apt_cmd)" autoremove -y || warn "autoremove encountered errors (non-fatal)."
            success "Purged ${BOLD}${pkg}${RESET}"
        elif is_installed_flatpak "$pkg"; then
            local appid
            appid=$(flatpak list --columns=application,name 2>/dev/null | grep -i "$pkg" | head -1 | awk '{print $1}')
            if [[ -n "$appid" ]]; then
                flatpak uninstall --noninteractive -y "$appid" \
                    || die "flatpak uninstall failed for ${BOLD}${pkg}${RESET}."
                rm -rf "$REAL_HOME/.var/app/$appid" || true
                success "Purged ${BOLD}${pkg}${RESET}"
            else
                die "Could not resolve flatpak ID for '${pkg}'."
            fi
        elif is_installed_snap "$pkg"; then
            sudo snap remove --purge "$pkg" || die "snap remove --purge failed for ${BOLD}${pkg}${RESET}."
            success "Purged ${BOLD}${pkg}${RESET}"
        else
            die "'${pkg}' not found in any backend."
        fi
        return
    fi

    info "Purging ${BOLD}${pkg}${RESET} [${backend}] + config/data..."

    case "$backend" in
        apt|dpkg)
            sudo "$(apt_cmd)" purge -y "$id" || die "apt purge failed for ${BOLD}${pkg}${RESET}."
            verify_apt_removed "$id"
            sudo "$(apt_cmd)" autoremove -y || warn "autoremove encountered errors (non-fatal)."
            ;;
        flatpak)
            flatpak uninstall --noninteractive -y "$id" \
                || die "flatpak uninstall failed for ${BOLD}${pkg}${RESET}."
            local flatpak_data="$REAL_HOME/.var/app/$id"
            if [[ -d "$flatpak_data" ]]; then
                rm -rf "$flatpak_data" \
                    && success "Removed app data: ${flatpak_data}" \
                    || warn "Could not remove app data: ${flatpak_data}"
            fi
            ;;
        snap)
            sudo snap remove --purge "$id" \
                || die "snap remove --purge failed for ${BOLD}${pkg}${RESET}."
            ;;
        appimage) remove_appimage "$pkg"; return ;;
        archive)
            if [[ -f "$id" ]]; then
                rm -f "$id" || die "Could not remove binary: ${id}"
                success "Removed binary: ${id}"
            else
                warn "Binary not found at recorded path: ${id}"
            fi
            registry_remove "$pkg"; return
            ;;
    esac

    registry_remove "$pkg"
    success "Purged ${BOLD}${pkg}${RESET}"
}

