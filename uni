#!/usr/bin/env bash
# ============================================================
#  uni — Universal Package Manager Wrapper v0.6.0-dev
#  Commands: uni install | uni remove | uni purge | uni list
#            uni search  | uni info   | uni index | uni sources
#            uni update  | uni self-update | uni intercept
#            uni uninstall | uni help | uni version
#
#  📚 Tutorial moved to walkthrough-installer.sh (run after installation)
#  ⚠️  Code improved with AI assistance
# ============================================================

set -u

UNI_VERSION="0.6.0-dev"
UNI_REPO="dronzer-tb/UNI"   # ← set this to your GitHub repo
UNI_RAW_URL="https://raw.githubusercontent.com/dronzer-tb/UNI/refs/heads/master/uni"

if [[ -n "${SUDO_USER:-}" ]]; then
    REAL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
else
    REAL_HOME="$HOME"
fi

UNI_REGISTRY="$REAL_HOME/.local/share/uni/installed.json"
UNI_APPIMAGE_DIR="$REAL_HOME/.local/share/uni/appimages"
UNI_DESKTOP_DIR="$REAL_HOME/.local/share/applications"
UNI_ICON_DIR="$REAL_HOME/.local/share/uni/icons"
UNI_DATA_DIR="$REAL_HOME/.local/share/uni"
UNI_INDEX_DB="$UNI_DATA_DIR/index.db"
UNI_SOURCES_JSON="$UNI_DATA_DIR/sources.json"
UNI_CACHE_DIR="$REAL_HOME/.cache/uni"
UNI_CACHE_TTL=3600          # 1 hour for search cache
UNI_SOURCES_TTL=3600        # 1 hour for source benchmark cache
UNI_UPDATE_CHECK_TTL=86400  # 24 hours for update-notifier check
UNI_JSON=0                  # set to 1 by --json flag; routes UI helpers to stderr and emits events

# ── Colors ───────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── UI Helpers ───────────────────────────────────────────────
# In JSON mode (UNI_JSON=1) all human-readable output goes to stderr so
# stdout stays a clean newline-delimited JSON event stream.
info()    { if (( UNI_JSON )); then echo -e "${CYAN}${BOLD} → ${RESET} $*" >&2; else echo -e "${CYAN}${BOLD} → ${RESET} $*"; fi; }
success() { if (( UNI_JSON )); then echo -e "${GREEN}${BOLD} ✓ ${RESET} $*" >&2; else echo -e "${GREEN}${BOLD} ✓ ${RESET} $*"; fi; }
warn()    { if (( UNI_JSON )); then echo -e "${YELLOW}${BOLD} ! ${RESET} $*" >&2; else echo -e "${YELLOW}${BOLD} ! ${RESET} $*"; fi; }
error()   { echo -e "${RED}${BOLD} ✗ ${RESET} $*" >&2; }
die()     {
    if (( UNI_JSON )) && [[ -n "${UNI_JSON_PKG:-}" ]]; then
        emit_event "$UNI_JSON_PKG" "done" "success=false" "error=$*"
    fi
    error "$*"; exit 1;
}
step()    { if (( UNI_JSON )); then echo -e "${MAGENTA}${BOLD} ⠿ ${RESET}${DIM}$*${RESET}" >&2; else echo -e "${MAGENTA}${BOLD} ⠿ ${RESET}${DIM}$*${RESET}"; fi; }
divider() { if (( UNI_JSON )); then echo -e "${DIM}────────────────────────────────────────${RESET}" >&2; else echo -e "${DIM}────────────────────────────────────────${RESET}"; fi; }
header()  { if (( UNI_JSON )); then echo "" >&2; echo -e "${BOLD}${BLUE}$*${RESET}" >&2; divider; else echo ""; echo -e "${BOLD}${BLUE}$*${RESET}"; divider; fi; }

# Emit a single newline-delimited JSON event to stdout (JSON mode).
# Usage: emit_event <package> <stage> [key=val]...
# stage is one of: resolving, downloading, installing, done.
emit_event() {
    (( UNI_JSON )) || return 0
    local pkg="$1" stage="$2"; shift 2
    python3 - "$pkg" "$stage" "$@" <<'PY' 2>/dev/null || true
import json, sys
pkg, stage = sys.argv[1], sys.argv[2]
ev = {"package": pkg, "stage": stage}
for kv in sys.argv[3:]:
    if "=" not in kv: continue
    k, v = kv.split("=", 1)
    if v in ("true", "false"):
        ev[k] = (v == "true")
    else:
        try: ev[k] = int(v)
        except ValueError:
            try: ev[k] = float(v)
            except ValueError: ev[k] = v
print(json.dumps(ev), flush=True)
PY
}

# ── Spinner ──────────────────────────────────────────────────
_SPIN_PID=""
spin_start() {
    local msg="$1"
    {
        local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
        local i=0
        while true; do
            printf "\r${CYAN}${BOLD} %s ${RESET}${DIM}%s${RESET}   " "${frames[$((i % ${#frames[@]}))]}" "$msg"
            sleep 0.08
            ((i++))
        done
    } &
    _SPIN_PID=$!
}

spin_stop() {
    if [[ -n "$_SPIN_PID" ]]; then
        kill "$_SPIN_PID" 2>/dev/null || true
        _SPIN_PID=""
        printf "\r\033[2K"
    fi
}

trap 'spin_stop' EXIT INT TERM

in_array() {
    local needle="$1"; shift
    local e
    for e in "$@"; do [[ "$e" == "$needle" ]] && return 0; done
    return 1
}

# ── Dependency Checks ────────────────────────────────────────
command -v python3 &>/dev/null || die "python3 is required but not installed."
command -v curl    &>/dev/null || die "curl is required but not installed."

if [[ -n "${SUDO_USER:-}" ]]; then
    warn "Running uni with sudo is not recommended."
    warn "User-level backends (Flatpak) may not be found under root's environment."
fi

# ── aria2c / parallel download helper ────────────────────────
has_aria2c() { command -v aria2c &>/dev/null; }

download_file() {
    local url="$1" dest="$2"
    if has_aria2c; then
        aria2c -x 8 -s 8 --allow-overwrite=true \
               -d "$(dirname "$dest")" \
               -o "$(basename "$dest")" \
               --console-log-level=warn \
               --summary-interval=0 \
               "$url" || return 1
    else
        curl -Lf# "$url" -o "$dest" || return 1
    fi
}

# ── Init registry ────────────────────────────────────────────
init_registry() {
    mkdir -p "$(dirname "$UNI_REGISTRY")" "$UNI_APPIMAGE_DIR" "$UNI_DESKTOP_DIR" \
             "$UNI_ICON_DIR" "$UNI_CACHE_DIR"
    [[ -f "$UNI_REGISTRY" ]] || echo '{}' > "$UNI_REGISTRY"
    if [[ -n "${SUDO_USER:-}" ]]; then
        chown -R "$SUDO_USER:$SUDO_USER" "$(dirname "$UNI_REGISTRY")" 2>/dev/null || true
    fi
}

# ── Registry helpers ─────────────────────────────────────────
registry_add() {
    local name="$1" backend="$2" id="$3"
    if command -v flock &>/dev/null; then
        (
            flock -x 200
            python3 - "$name" "$backend" "$id" "$UNI_REGISTRY" << 'PYEOF'
import json, sys
import os
import tempfile
name, backend, id_val, reg_path = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
try:
    with open(reg_path) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d[name] = {'backend': backend, 'id': id_val}
dirpath = os.path.dirname(reg_path) or '.'
fd, tmp = tempfile.mkstemp(dir=dirpath)
with os.fdopen(fd, 'w') as f:
    json.dump(d, f, indent=2)
os.replace(tmp, reg_path)
PYEOF
        ) 200>"${UNI_REGISTRY}.lock"
    else
        python3 - "$name" "$backend" "$id" "$UNI_REGISTRY" << 'PYEOF'
import json, sys
import os
import tempfile
name, backend, id_val, reg_path = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
try:
    with open(reg_path) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d[name] = {'backend': backend, 'id': id_val}
dirpath = os.path.dirname(reg_path) or '.'
fd, tmp = tempfile.mkstemp(dir=dirpath)
with os.fdopen(fd, 'w') as f:
    json.dump(d, f, indent=2)
os.replace(tmp, reg_path)
PYEOF
    fi
}

registry_remove() {
    local name="$1"
    if command -v flock &>/dev/null; then
        (
            flock -x 200
            python3 - "$name" "$UNI_REGISTRY" << 'PYEOF'
import json, sys
import os
import tempfile
name, reg_path = sys.argv[1], sys.argv[2]
try:
    with open(reg_path) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d.pop(name, None)
dirpath = os.path.dirname(reg_path) or '.'
fd, tmp = tempfile.mkstemp(dir=dirpath)
with os.fdopen(fd, 'w') as f:
    json.dump(d, f, indent=2)
os.replace(tmp, reg_path)
PYEOF
        ) 200>"${UNI_REGISTRY}.lock"
    else
        python3 - "$name" "$UNI_REGISTRY" << 'PYEOF'
import json, sys
import os
import tempfile
name, reg_path = sys.argv[1], sys.argv[2]
try:
    with open(reg_path) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d.pop(name, None)
dirpath = os.path.dirname(reg_path) or '.'
fd, tmp = tempfile.mkstemp(dir=dirpath)
with os.fdopen(fd, 'w') as f:
    json.dump(d, f, indent=2)
os.replace(tmp, reg_path)
PYEOF
    fi
}

registry_get() {
    local name="$1" field="$2"
    python3 - "$name" "$field" "$UNI_REGISTRY" << 'PYEOF'
import json, sys
name, field, reg_path = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(reg_path) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
print(d.get(name, {}).get(field, ''))
PYEOF
}

registry_list() {
    python3 - "$UNI_REGISTRY" << 'PYEOF'
import json, sys
reg_path = sys.argv[1]
try:
    with open(reg_path) as f: d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
if not d:
    print('  No packages installed via uni.')
else:
    for name, info in sorted(d.items()):
        print(f"  {name:<32} [{info['backend']:<10}]  {info['id']}")
