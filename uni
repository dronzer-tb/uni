# ── Entry point ──────────────────────────────────────────────
main() {
    # Kick off background update check on every run (non-blocking)
    check_for_update

    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        install)                cmd_install "$@" ;;
        remove)                 cmd_remove  "$@" ;;
        purge)                  cmd_purge   "$@" ;;
        list)                   cmd_list ;;
        update)                 cmd_update ;;
        self-update|--update)   cmd_self_update ;;
        uninstall)              cmd_uninstall ;;
        intercept)              cmd_intercept "$@" ;;
        
        version|--version|-V)   echo "uni v${UNI_VERSION}" ;;
        help|--help|-h)         cmd_help ;;
        *) error "Unknown command: ${cmd}"; cmd_help; exit 1 ;;
    esac

    # Print update banner after the command finishes (if one was found)
    print_update_banner
}

main "$@"
